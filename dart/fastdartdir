#!/bin/bash
# Usage: fastdartdir PACKAGE_NAME
# Creates ./PACKAGE_NAME in the current working directory using template/ next to this script.

set -euo pipefail

usage() {
  echo "Usage: fastdartdir PACKAGE_NAME" >&2
  exit 1
}

[[ $# -eq 1 ]] || usage
NAME="$1"

if [[ ! "$NAME" =~ ^[a-z][a-z0-9_]*$ ]]; then
  echo "fastdartdir: invalid package name (use lowercase letters, digits, underscores; start with a letter)" >&2
  exit 1
fi

_script_resolve() {
  local src="${BASH_SOURCE[0]}"
  while [[ -h "$src" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  printf '%s' "$(cd -P "$(dirname "$src")" && pwd)"
}

SCRIPT_DIR="$(_script_resolve)"
TEMPLATE="$SCRIPT_DIR/template"

if [[ ! -f "$TEMPLATE/pubspec.yaml" || ! -f "$TEMPLATE/analysis_options.yaml" || ! -f "$TEMPLATE/lib/main.dart" ]]; then
  echo "fastdartdir: missing template under $TEMPLATE" >&2
  exit 1
fi

if [[ -e "$NAME" ]]; then
  echo "fastdartdir: path already exists: $PWD/$NAME" >&2
  exit 1
fi

mkdir -p "$NAME/lib"
sed "s/{{PACKAGE_NAME}}/$NAME/g" "$TEMPLATE/pubspec.yaml" >"$NAME/pubspec.yaml"
cp "$TEMPLATE/analysis_options.yaml" "$NAME/analysis_options.yaml"
cp "$TEMPLATE/lib/main.dart" "$NAME/lib/main.dart"

echo "Created $PWD/$NAME"
